{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Library component templates that ship with warphead.dev - automatically loaded on app initialization",
  "version": "1.0.0",
  "components": [
    {
      "component_name": "Simple Card",
      "component_type": "SimpleCard",
      "description": "A simple card component using only Tailwind CSS with a customizable title",
      "tags": "card,basic,simple,tailwind",
      "frameworks": "tailwind",
      "html_code": "<script>\n  // Component props\n  export let title = 'Data loads';\n  export let text = 'Manage data ingestion and settings';\n</script>\n\n<div class=\"bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 hover:shadow-lg transition-shadow\">\n  <h3 class=\"text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2\">\n    {title}\n  </h3>\n  <p class=\"text-sm text-slate-600 dark:text-slate-400\">\n    {text}\n  </p>\n</div>",
      "css_code": "",
      "js_code": "",
      "min_metrics": 0,
      "max_metrics": 0,
      "min_dimensions": 0,
      "max_dimensions": 0
    },
    {
      "component_name": "Tabs",
      "component_type": "Tabs",
      "description": "A responsive tabbed interface - dropdown on mobile, tabs on desktop",
      "tags": "tabs,navigation,layout,tailwind,responsive",
      "frameworks": "tailwind",
      "html_code": "<script>\n  // Component props\n  export let tabs = [\n    { label: 'My Account', content: 'Content for My Account' },\n    { label: 'Company', content: 'Content for Company' },\n    { label: 'Team Members', content: 'Content for Team Members', active: true },\n    { label: 'Billing', content: 'Content for Billing' }\n  ];\n</script>\n\n<div>\n  <!-- Mobile: Dropdown -->\n  <div class=\"grid grid-cols-1 sm:hidden\">\n    <select aria-label=\"Select a tab\" class=\"col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-2 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-gray-100 dark:outline-white/10 dark:focus:outline-indigo-500\">\n      {#each tabs as tab}\n        <option>{tab.label}</option>\n      {/each}\n    </select>\n    <svg viewBox=\"0 0 16 16\" fill=\"currentColor\" data-slot=\"icon\" aria-hidden=\"true\" class=\"pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end fill-gray-500 dark:fill-gray-400\">\n      <path d=\"M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z\" clip-rule=\"evenodd\" fill-rule=\"evenodd\" />\n    </svg>\n  </div>\n  \n  <!-- Desktop: Tabs -->\n  <div class=\"hidden sm:block\">\n    <nav aria-label=\"Tabs\" class=\"flex space-x-4\">\n      {#each tabs as tab}\n        <a href=\"#\" class=\"rounded-md px-3 py-2 text-sm font-medium {tab.active ? 'bg-gray-100 text-gray-700 dark:bg-white/10 dark:text-gray-200' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'}\">\n          {tab.label}\n        </a>\n      {/each}\n    </nav>\n  </div>\n  \n  <!-- Tab Content -->\n  <div class=\"mt-4\">\n    {#each tabs as tab}\n      {#if tab.active}\n        <div class=\"text-gray-900 dark:text-gray-100\">\n          {tab.content}\n        </div>\n      {/if}\n    {/each}\n  </div>\n</div>",
      "css_code": "",
      "js_code": "",
      "min_metrics": 0,
      "max_metrics": 0,
      "min_dimensions": 0,
      "max_dimensions": 0
    }
  ]
}
