{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5.1",
  "autoupdate": true,
  "instructions": [
    ".davia/davia-documentation.md",
    ".worker/.mcp/mcp-instructions.md"
  ],
  "mcp": {
    "time-server": {
      "type": "remote",
      "url": "https://mcp.time.mcpcentral.io"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
